# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  terraform.tfvars.example                                                  ║
# ║  Copy to terraform.tfvars and fill in your values.                         ║
# ║  NEVER commit terraform.tfvars to version control.                         ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── Provider / Tenancy ───────────────────────────────────────────────────────

tenancy_ocid     = "ocid1.tenancy.oc1..aaaa..."
user_ocid        = "ocid1.user.oc1..aaaa..."
fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "us-ashburn-1"

# ─── Compartments ─────────────────────────────────────────────────────────────

poc_compartment_ocid = "ocid1.compartment.oc1..aaaa..."
dev_compartment_ocid = "ocid1.compartment.oc1..aaaa..."

# ─── Network CIDRs (defaults shown — override if needed) ─────────────────────

# poc_vcn_cidr        = "192.168.150.0/24"
# dev_vcn_cidr        = "192.168.151.0/24"
# adb_subnet_cidr     = "192.168.150.0/26"
# oac_pac_subnet_cidr = "192.168.150.64/26"
# dev_db_subnet_cidr  = "192.168.151.0/26"

# ─── Compute Subnets (defaults shown — override if needed) ──────────────────

# poc_compute_subnet_cidr = "192.168.150.128/26"
# dev_compute_subnet_cidr = "192.168.151.64/26"

# ─── Compute Instances ──────────────────────────────────────────────────────

instance_image_ocid = "ocid1.image.oc1.iad.aaaa..."   # Oracle Linux image OCID
# SSH key is auto-generated — retrieve with: terraform output -raw ssh_private_key_pem > compute.pem

# instance_shape              = "VM.Standard.E4.Flex"
# instance_shape_ocpus        = 1
# instance_shape_memory_in_gbs = 16

# ─── ADB-S Listener ──────────────────────────────────────────────────────────

# adb_is_mtls_required = true   # true = port 1522, false = 1521

# ─── Tags ─────────────────────────────────────────────────────────────────────

# freeform_tags = {
#   Environment = "POC"
#   Project     = "OAC-ADB-Private-Endpoint"
#   ManagedBy   = "Terraform"
# }
